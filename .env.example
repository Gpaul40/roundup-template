# ═══════════════════════════════════════════════════════════════════════════
#  Copy this file to .env.local for local development.
#  On Vercel, add the same variables under Project → Settings → Environment
#  Variables.
# ═══════════════════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────────────────────
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Keep this one SECRET — it bypasses all database security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Sessions ─────────────────────────────────────────────────────────────────
# Any long random string. Generate one with:  openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# ── Member passwords ─────────────────────────────────────────────────────────
# One PASSWORD_<NAME> variable for each member in config/group.ts.
# The variable name must match the member name in UPPERCASE.
PASSWORD_ALEX=pick-a-password
PASSWORD_BLAKE=pick-a-password
PASSWORD_CASEY=pick-a-password
PASSWORD_DYLAN=pick-a-password
PASSWORD_EDEN=pick-a-password
